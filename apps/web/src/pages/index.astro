---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "aipm";
const description = "Claude Code is for coding. This is for PM-ing.";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox → task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">aipm<span class="cursor">_</span></h1>
    <p class="hero-tagline">Claude Code is for coding. <span class="hero-tagline-highlight">This is for PM-ing.</span></p>
    <pre
      class="install-cmd"
      onclick="navigator.clipboard.writeText('brew tap ComputelessComputer/aipm && brew install aipm'); const prompt = this.querySelector('.terminal-prompt'); prompt.textContent = '✓'; this.classList.add('copied'); clearTimeout(this.copyTimer); this.copyTimer = setTimeout(() => { prompt.textContent = '$'; this.classList.remove('copied'); }, 1200);"
      title="Click to copy"
    ><code><span class="terminal-prompt" aria-hidden="true">$</span><span>brew tap ComputelessComputer/aipm && brew install aipm</span></code></pre>
  </section>

  <!-- Value Props -->
  <section class="value-props">
    <div class="prop">
      <h3>local-first</h3>
      <p>Your tasks live as plain files on your filesystem. No servers, no sync, no lock-in. Grep, sed, or script your way through everything.</p>
    </div>
    <div class="prop">
      <h3>cli-first</h3>
      <p>Headless commands with JSON output. Built for scripting and AI coding agents. Works as well in a pipeline as it does interactively.</p>
    </div>
    <div class="prop">
      <h3>super fast</h3>
      <p>Native Rust TUI. Instant startup, zero latency navigation, no Electron, no browser. Just your terminal.</p>
    </div>
  </section>

  <!-- Demo -->
  <section class="demo">
    <h2>demo</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>features</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .hero-title {
    font-size: 4rem;
    margin-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 5rem;
    }
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    white-space: nowrap;
  }

  .hero-tagline-highlight {
    color: var(--color-accent);
    font-weight: 600;
  }

  .install-cmd {
    display: inline-block;
    width: fit-content;
    max-width: 100%;
    text-align: center;
    cursor: pointer;
    border-radius: 10px;
    border: 1px solid #1f2229;
    background: #090b10;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    padding: 1rem 1.1rem;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .install-cmd:hover {
    border-color: #2f3440;
    background: #0b0e15;
  }

  .install-cmd:active {
    background: #090b10;
  }

  .install-cmd code {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    color: #d8dde8;
    font-size: clamp(0.9rem, 2.2vw, 1.05rem);
    line-height: 1.35;
    padding: 0;
    white-space: nowrap;
  }

  .terminal-prompt {
    color: #d8dde8;
    opacity: 0.9;
    margin-right: 0.6ch;
    user-select: none;
    -webkit-user-select: none;
  }

  .install-cmd.copied .terminal-prompt {
    color: #00ff88;
    opacity: 1;
  }

  @media (max-width: 640px) {
    .install-cmd {
      display: block;
      width: 100%;
      padding: 0.85rem 0.9rem;
    }

    .install-cmd code {
      overflow-x: auto;
      display: flex;
      justify-content: flex-start;
    }
  }

  /* Value Props */
  .value-props {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .value-props {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .prop {
    padding: var(--space-lg);
  }

  .prop h3 {
    font-size: 1.125rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .prop p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    color: var(--color-accent);
    transition: all var(--transition-fast);
  }

  .cta-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  /* Demo */
  .demo {
    padding: var(--space-2xl) 0;
  }

  .demo h2 {
    margin-bottom: var(--space-lg);
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Features */
  .features {
    padding: var(--space-2xl) 0;
  }

  .features h2 {
    margin-bottom: var(--space-lg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature {
    padding: var(--space-lg);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .feature h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .feature p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

</style>
