---
import BaseLayout from '../layouts/BaseLayout.astro';
import CheckIcon from '../components/CheckIcon';

const title = "aipm";
const description = "Claude Code is for coding. This is for PM-ing.";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox -> task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="section-kicker"><span class="kicker-dot"></span>vision</p>
        <h1 class="hero-title">Run every project with execution-grade AI orchestration, from inbox to roadmap to shipped work with local tasks and real tool execution.</h1>
        <pre
          class="install-cmd"
          onclick="navigator.clipboard.writeText('brew tap ComputelessComputer/aipm && brew install aipm'); const prompt = this.querySelector('.terminal-prompt'); if (!prompt) return; prompt.classList.add('copied'); this.classList.add('copied'); clearTimeout(this.copyTimer); this.copyTimer = setTimeout(() => { prompt.classList.remove('copied'); this.classList.remove('copied'); }, 1200);"
          title="Click to copy"
        ><code><span class="terminal-prompt" aria-hidden="true"><span class="prompt-dollar">$</span><span class="prompt-check"><CheckIcon size={16} strokeWidth={2.5} /></span></span><span>brew tap ComputelessComputer/aipm && brew install aipm</span></code></pre>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <span class="ribbon ribbon-a"></span>
        <span class="ribbon ribbon-b"></span>
        <span class="ribbon ribbon-c"></span>
        <span class="ribbon ribbon-d"></span>
      </div>
    </div>
  </section>

  <section class="value-props">
    <p class="section-kicker"><span class="kicker-dot"></span>foundation</p>
    <div class="value-grid">
      <div class="prop">
        <h3>local-first</h3>
        <p>Your tasks live as plain files on your filesystem. No servers, no sync, no lock-in. Grep, sed, or script your way through everything.</p>
      </div>
      <div class="prop">
        <h3>cli-first</h3>
        <p>Headless commands with JSON output. Built for scripting and AI coding agents. Works as well in a pipeline as it does interactively.</p>
      </div>
      <div class="prop">
        <h3>super fast</h3>
        <p>Native Rust TUI. Instant startup, zero latency navigation, no Electron, no browser. Just your terminal.</p>
      </div>
    </div>
  </section>

  <section class="demo">
    <p class="section-kicker"><span class="kicker-dot"></span>demo</p>
    <h2>Watch aipm in flow</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section class="features">
    <p class="section-kicker"><span class="kicker-dot"></span>features</p>
    <h2>Agent-native task operations</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a7a68;
  }

  .kicker-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #c07a3e, #d4a574);
  }

  .hero {
    position: relative;
    padding: clamp(1.8rem, 3.8vw, 3rem);
    padding-bottom: clamp(2.8rem, 5vw, 4.8rem);
    border: none;
    border-radius: 0;
    background: none;
    color: #2c2418;
    text-align: left;
    overflow: hidden;
  }

  .hero .section-kicker {
    color: #8a7a68;
  }

  .hero .kicker-dot {
    background: linear-gradient(135deg, #c07a3e, #d4a574);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.8rem, 3.5vw, 3.4rem);
    justify-items: start;
  }

  .hero-copy {
    max-width: 760px;
    justify-self: start;
  }

  .hero-title {
    margin-bottom: 1.45rem;
    line-height: 1.03;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    max-width: 20ch;
    color: #2c2418;
  }

  .install-cmd {
    display: inline-block;
    width: fit-content;
    max-width: 100%;
    text-align: left;
    cursor: pointer;
    border-radius: 10px;
    border: 1px solid #e5dbc8;
    background: #f3ede4;
    box-shadow: 0 8px 18px rgba(44, 36, 24, 0.06);
    padding: 0.9rem 1rem;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .install-cmd:hover {
    border-color: #d4c4a8;
    background: #fffdfb;
  }

  .install-cmd code {
    display: flex;
    align-items: center;
    color: #2c2418;
    font-size: clamp(0.86rem, 1.45vw, 1rem);
    line-height: 1.35;
    white-space: nowrap;
    overflow-x: auto;
    background: none;
    border: 0;
    padding: 0;
  }

  .terminal-prompt {
    display: inline-flex;
    align-items: center;
    color: #c07a3e;
    margin-right: 0.6ch;
    user-select: none;
    -webkit-user-select: none;
  }

  .prompt-check {
    display: none;
    line-height: 0;
  }

  .terminal-prompt.copied .prompt-dollar {
    display: none;
  }

  .terminal-prompt.copied .prompt-check {
    display: inline-flex;
  }

  .install-cmd.copied .terminal-prompt {
    color: #5a9a6b;
  }

  .hero-visual {
    position: relative;
    border: 1px solid #e5dbc8;
    background: linear-gradient(180deg, #f7f1e8 0%, #f3ede4 100%);
    border-radius: 12px;
    min-height: 280px;
    overflow: hidden;
    justify-self: stretch;
    width: 100%;
  }

  .ribbon {
    position: absolute;
    border-radius: 999px;
    transform-origin: center;
    filter: saturate(90%);
  }

  .ribbon-a {
    width: 520px;
    height: 140px;
    right: -170px;
    top: 20px;
    transform: rotate(-36deg);
    background: linear-gradient(90deg, rgba(192, 122, 62, 0) 0%, rgba(192, 122, 62, 0.55) 44%, rgba(212, 165, 116, 0.7) 100%);
  }

  .ribbon-b {
    width: 540px;
    height: 160px;
    right: -170px;
    top: 110px;
    transform: rotate(-36deg);
    background: linear-gradient(90deg, rgba(180, 120, 80, 0) 4%, rgba(180, 120, 80, 0.5) 45%, rgba(210, 170, 110, 0.65) 100%);
  }

  .ribbon-c {
    width: 560px;
    height: 120px;
    right: -190px;
    top: 205px;
    transform: rotate(-36deg);
    background: linear-gradient(90deg, rgba(140, 160, 120, 0) 0%, rgba(140, 160, 120, 0.45) 46%, rgba(192, 160, 110, 0.55) 100%);
  }

  .ribbon-d {
    width: 450px;
    height: 80px;
    right: -150px;
    top: 14px;
    transform: rotate(-36deg);
    opacity: 0.55;
    background: linear-gradient(90deg, rgba(212, 180, 130, 0) 0%, rgba(212, 180, 130, 0.5) 52%, rgba(192, 150, 100, 0.55) 100%);
  }

  .value-props,
  .demo,
  .features {
    padding-top: clamp(2.2rem, 4.5vw, 4.2rem);
  }

  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .prop {
    border: 1px solid var(--color-border);
    background: #fffdfb;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .prop h3 {
    font-size: 1.18rem;
    margin-bottom: 0.55rem;
    color: var(--color-text);
  }

  .prop p {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-secondary);
    line-height: 1.6;
  }

  .demo h2,
  .features h2 {
    margin-bottom: 1.2rem;
    max-width: 16ch;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: #f7f1e8;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature {
    border: 1px solid var(--color-border);
    background: #fffdfb;
    border-radius: 10px;
    padding: 1.15rem;
  }

  .feature h3 {
    font-size: 1.02rem;
    margin-bottom: 0.4rem;
  }

  .feature p {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-secondary);
    line-height: 1.5;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      align-items: stretch;
    }

    .value-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .install-cmd {
      display: block;
      width: 100%;
      padding: 0.8rem 0.88rem;
    }

    .install-cmd code {
      justify-content: flex-start;
    }

    .hero-visual {
      min-height: 220px;
    }

    .ribbon-a,
    .ribbon-b,
    .ribbon-c,
    .ribbon-d {
      right: -220px;
      transform: rotate(-39deg);
    }
  }
</style>
