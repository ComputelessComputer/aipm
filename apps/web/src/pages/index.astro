---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "aipm";
const description = "Claude Code is for coding. This is for PM-ing.";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox -> task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="section-kicker"><span class="kicker-dot"></span>vision</p>
        <h1 class="hero-title">aipm<span class="cursor">_</span></h1>
        <p class="hero-tagline">Claude Code is for coding. <span class="hero-tagline-highlight">This is for PM-ing.</span></p>
        <p class="hero-desc">The AI project manager built for terminal operators. Tasks stay local as files, and the agent executes work through real tools instead of hand-wavy summaries.</p>
        <pre
          class="install-cmd"
          onclick="navigator.clipboard.writeText('brew tap ComputelessComputer/aipm && brew install aipm'); const prompt = this.querySelector('.terminal-prompt'); prompt.textContent = '✓'; this.classList.add('copied'); clearTimeout(this.copyTimer); this.copyTimer = setTimeout(() => { prompt.textContent = '$'; this.classList.remove('copied'); }, 1200);"
          title="Click to copy"
        ><code><span class="terminal-prompt" aria-hidden="true">$</span><span>brew tap ComputelessComputer/aipm && brew install aipm</span></code></pre>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="signal-row"><span class="signal-dot accent"></span><span class="signal-dot"></span><span class="signal-dot"></span><span class="signal-dot accent"></span></div>
        <div class="signal-row"><span class="signal-dot"></span><span class="signal-dot accent"></span><span class="signal-dot"></span><span class="signal-dot"></span></div>
        <div class="signal-row"><span class="signal-dot"></span><span class="signal-dot"></span><span class="signal-dot accent"></span><span class="signal-dot"></span></div>
        <div class="signal-row"><span class="signal-dot accent"></span><span class="signal-dot"></span><span class="signal-dot"></span><span class="signal-dot"></span></div>
        <div class="signal-row"><span class="signal-dot"></span><span class="signal-dot"></span><span class="signal-dot accent"></span><span class="signal-dot"></span></div>
      </div>
    </div>
  </section>

  <section class="value-props">
    <p class="section-kicker"><span class="kicker-dot"></span>foundation</p>
    <div class="value-grid">
      <div class="prop">
        <h3>local-first</h3>
        <p>Your tasks live as plain files on your filesystem. No servers, no sync, no lock-in. Grep, sed, or script your way through everything.</p>
      </div>
      <div class="prop">
        <h3>cli-first</h3>
        <p>Headless commands with JSON output. Built for scripting and AI coding agents. Works as well in a pipeline as it does interactively.</p>
      </div>
      <div class="prop">
        <h3>super fast</h3>
        <p>Native Rust TUI. Instant startup, zero latency navigation, no Electron, no browser. Just your terminal.</p>
      </div>
    </div>
  </section>

  <section class="demo">
    <p class="section-kicker"><span class="kicker-dot"></span>demo</p>
    <h2>Watch aipm in flow</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section class="features">
    <p class="section-kicker"><span class="kicker-dot"></span>features</p>
    <h2>Agent-native task operations</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #b6bee2;
  }

  .kicker-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #6d63ff, #ff8a4c);
  }

  .hero {
    position: relative;
    padding-bottom: clamp(2.8rem, 5vw, 4.8rem);
    border-bottom: 1px solid var(--color-border);
    text-align: left;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(135deg, rgba(125, 138, 255, 0.09) 0, rgba(125, 138, 255, 0.09) 1px, transparent 1px, transparent 9px);
    opacity: 0.38;
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    top: -18%;
    right: -22%;
    width: min(64vw, 860px);
    height: min(64vw, 860px);
    border-radius: 50%;
    background: conic-gradient(from 215deg at 50% 50%, rgba(96, 85, 255, 0.96), rgba(255, 121, 67, 0.92), rgba(243, 91, 228, 0.82), rgba(96, 85, 255, 0.96));
    filter: blur(38px) saturate(115%);
    opacity: 0.26;
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.8rem, 3.5vw, 3.4rem);
    justify-items: start;
  }

  .hero-copy {
    max-width: 800px;
    justify-self: start;
  }

  .hero-title {
    margin-bottom: 0.95rem;
    line-height: 0.95;
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-tagline {
    margin-bottom: 0.95rem;
    font-size: clamp(1rem, 1.7vw, 1.7rem);
    color: #b4bcdf;
    white-space: nowrap;
  }

  .hero-tagline-highlight {
    background: linear-gradient(90deg, #938bff 0%, #69d5ff 42%, #ff9a59 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 600;
  }

  .hero-desc {
    max-width: 64ch;
    margin-bottom: 1.45rem;
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    line-height: 1.52;
    color: #d6ddfa;
  }

  .install-cmd {
    display: inline-block;
    width: fit-content;
    max-width: 100%;
    text-align: left;
    cursor: pointer;
    border-radius: 10px;
    border: 1px solid rgba(116, 133, 226, 0.55);
    background: linear-gradient(140deg, rgba(22, 30, 68, 0.95), rgba(13, 20, 51, 0.9));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14), 0 10px 26px rgba(7, 9, 20, 0.45);
    padding: 0.9rem 1rem;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .install-cmd:hover {
    border-color: rgba(144, 154, 246, 0.8);
    background: linear-gradient(140deg, rgba(28, 39, 84, 0.96), rgba(16, 25, 58, 0.93));
  }

  .install-cmd code {
    display: flex;
    align-items: center;
    color: #e4e9ff;
    font-size: clamp(0.86rem, 1.45vw, 1rem);
    line-height: 1.35;
    white-space: nowrap;
    overflow-x: auto;
    background: none;
    border: 0;
    padding: 0;
  }

  .terminal-prompt {
    color: #7f76ff;
    margin-right: 0.6ch;
    user-select: none;
    -webkit-user-select: none;
  }

  .install-cmd.copied .terminal-prompt {
    color: #3ed6a4;
  }

  .hero-visual {
    border: 1px solid rgba(122, 138, 232, 0.42);
    background: radial-gradient(circle at 12% 10%, rgba(140, 120, 255, 0.19), transparent 38%), radial-gradient(circle at 95% 95%, rgba(255, 144, 84, 0.16), transparent 40%), linear-gradient(160deg, rgba(20, 28, 64, 0.8), rgba(13, 19, 46, 0.85));
    border-radius: 12px;
    padding: clamp(1.2rem, 2.8vw, 1.8rem);
    min-height: 260px;
    display: grid;
    gap: 1.45rem;
    align-content: center;
    justify-self: stretch;
    width: 100%;
  }

  .signal-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    padding-top: 0.72rem;
    border-top: 1px dashed rgba(140, 153, 228, 0.35);
  }

  .signal-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #8d98d2;
  }

  .signal-dot.accent {
    background: linear-gradient(135deg, #6f66ff, #ff8e54);
  }

  .value-props,
  .demo,
  .features {
    padding-top: clamp(2.2rem, 4.5vw, 4.2rem);
  }

  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .prop {
    border: 1px solid rgba(105, 124, 212, 0.45);
    background: linear-gradient(160deg, rgba(21, 30, 68, 0.68), rgba(14, 21, 48, 0.82));
    border-radius: 10px;
    padding: 1.25rem;
  }

  .prop h3 {
    font-size: 1.18rem;
    margin-bottom: 0.55rem;
    color: var(--color-text);
  }

  .prop p {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: #d2daf8;
    line-height: 1.6;
  }

  .demo h2,
  .features h2 {
    margin-bottom: 1.2rem;
    max-width: 16ch;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(105, 124, 212, 0.45);
    background: #0a1434;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature {
    border: 1px solid rgba(105, 124, 212, 0.45);
    background: linear-gradient(160deg, rgba(20, 29, 66, 0.7), rgba(13, 20, 45, 0.84));
    border-radius: 10px;
    padding: 1.15rem;
  }

  .feature h3 {
    font-size: 1.02rem;
    margin-bottom: 0.4rem;
  }

  .feature p {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: #d2daf8;
    line-height: 1.5;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      align-items: end;
    }

    .value-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero-tagline {
      font-size: 0.95rem;
    }

    .install-cmd {
      display: block;
      width: 100%;
      padding: 0.8rem 0.88rem;
    }

    .install-cmd code {
      justify-content: flex-start;
    }
  }
</style>
