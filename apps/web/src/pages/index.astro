---
import BaseLayout from '../layouts/BaseLayout.astro';
import CheckIcon from '../components/CheckIcon';

const title = "aipm";
const description = "Claude Code is for coding. This is for PM-ing.";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox -> task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="section-kicker"><span class="kicker-dot"></span>vision</p>
        <h1 class="hero-title"><span style="opacity: 0.4;">Claude Code is for coding.</span><br />aipm is for PM-ing.</h1>
        <pre
          class="install-cmd"
          title="Click to copy"
        ><code><span class="terminal-prompt" aria-hidden="true">$</span><span>brew tap ComputelessComputer/aipm && brew install aipm</span><button class="copy-btn" type="button" onclick="navigator.clipboard.writeText('brew tap ComputelessComputer/aipm && brew install aipm'); const btn = this; btn.classList.add('copied'); clearTimeout(btn.copyTimer); btn.copyTimer = setTimeout(() => btn.classList.remove('copied'), 1200);" aria-label="Copy to clipboard"><span class="copy-icon"><svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect width='14' height='14' x='8' y='8' rx='2' ry='2'/><path d='M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2'/></svg></span><span class="check-icon"><svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg></span></button></code></pre>
      </div>
    </div>
  </section>

  <section class="value-props">
    <p class="section-kicker"><span class="kicker-dot"></span>foundation</p>
    <div class="value-grid">
      <div class="prop">
        <h3>local-first</h3>
        <p>Your tasks live as plain files on your filesystem. No servers, no sync, no lock-in. Grep, sed, or script your way through everything.</p>
      </div>
      <div class="prop">
        <h3>cli-first</h3>
        <p>Headless commands with JSON output. Built for scripting and AI coding agents. Works as well in a pipeline as it does interactively.</p>
      </div>
      <div class="prop">
        <h3>super fast</h3>
        <p>Native Rust TUI. Instant startup, zero latency navigation, no Electron, no browser. Just your terminal.</p>
      </div>
    </div>
  </section>

  <section class="demo">
    <p class="section-kicker"><span class="kicker-dot"></span>demo</p>
    <h2>Watch aipm in flow</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section class="features">
    <p class="section-kicker"><span class="kicker-dot"></span>features</p>
    <h2>Agent-native task operations</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const kickers = document.querySelectorAll('.section-kicker');

    if (!kickers.length) {
      return;
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const lightDot = (kicker) => {
      const dot = kicker.querySelector('.kicker-dot');

      if (!dot) {
        return;
      }

      if (reducedMotion) {
        dot.classList.add('is-lit');
        return;
      }

      dot.classList.add('blink-in');
      dot.addEventListener(
        'animationend',
        () => {
          dot.classList.remove('blink-in');
          dot.classList.add('is-lit');
        },
        { once: true }
      );
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) {
            continue;
          }

          lightDot(entry.target);
          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.35 }
    );

    for (const kicker of kickers) {
      observer.observe(kicker);
    }
  })();
</script>

<style>
  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a7a68;
  }

  .kicker-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #c07a3e, #d4a574);
    opacity: 0.28;
    box-shadow: 0 0 0 rgba(192, 122, 62, 0);
  }

  .kicker-dot.blink-in {
    animation: kicker-dot-blink 540ms linear 1 forwards;
  }

  .kicker-dot.is-lit {
    opacity: 1;
    box-shadow: 0 0 0.5rem rgba(192, 122, 62, 0.45);
  }

  @keyframes kicker-dot-blink {
    0%,
    8% {
      opacity: 0.2;
      box-shadow: 0 0 0 rgba(192, 122, 62, 0);
    }

    16%,
    26% {
      opacity: 1;
      box-shadow: 0 0 0.5rem rgba(192, 122, 62, 0.45);
    }

    34%,
    44% {
      opacity: 0.2;
      box-shadow: 0 0 0 rgba(192, 122, 62, 0);
    }

    52%,
    62% {
      opacity: 1;
      box-shadow: 0 0 0.5rem rgba(192, 122, 62, 0.45);
    }

    70%,
    80% {
      opacity: 0.2;
      box-shadow: 0 0 0 rgba(192, 122, 62, 0);
    }

    88%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0.5rem rgba(192, 122, 62, 0.45);
    }
  }

  .hero {
    position: relative;
    color: #2c2418;
    text-align: left;
    overflow: hidden;
  }

  .hero .section-kicker {
    color: #8a7a68;
  }

  .hero .kicker-dot {
    background: linear-gradient(135deg, #c07a3e, #d4a574);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.8rem, 3.5vw, 3.4rem);
    justify-items: start;
  }

  .hero-copy {
    max-width: 100%;
    justify-self: start;
  }

  .hero-title {
    margin-bottom: 1.45rem;
    line-height: 1.03;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    max-width: 100%;
    color: #2c2418;
  }

  .install-cmd {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    text-align: left;
    border-radius: 10px;
    border: 1px solid #e5dbc8;
    background: #ffffff;
    padding: 0.9rem 1rem;
  }


  .install-cmd code {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #2c2418;
    font-size: clamp(0.86rem, 1.45vw, 1rem);
    line-height: 1.35;
    white-space: nowrap;
    overflow-x: auto;
    background: none;
    border: 0;
    padding: 0;
    width: 100%;
  }

  .terminal-prompt {
    color: #c07a3e;
    margin-right: 0.6ch;
    user-select: none;
    -webkit-user-select: none;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    padding: 0.3rem;
    background: none;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    color: #9d8c78;
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: #c07a3e;
  }

  .copy-btn .check-icon {
    display: none;
    line-height: 0;
  }

  .copy-btn .copy-icon {
    display: inline-flex;
    line-height: 0;
  }

  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: inline-flex;
  }

  .copy-btn.copied {
    color: #5a9a6b;
  }


  .value-props,
  .demo,
  .features {
    padding-top: clamp(2.2rem, 4.5vw, 4.2rem);
  }

  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .prop {
    border: 1px solid var(--color-border);
    background: #fffdfb;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .prop h3 {
    font-size: 1.18rem;
    margin-bottom: 0.55rem;
    color: var(--color-text);
  }

  .prop p {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-secondary);
    line-height: 1.6;
  }

  .demo h2,
  .features h2 {
    margin-bottom: 1.2rem;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: #f7f1e8;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature {
    border: 1px solid var(--color-border);
    background: #fffdfb;
    border-radius: 10px;
    padding: 1.15rem;
  }

  .feature h3 {
    font-size: 1.02rem;
    margin-bottom: 0.4rem;
  }

  .feature p {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-secondary);
    line-height: 1.5;
  }

  @media (min-width: 900px) {

    .value-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .install-cmd {
      display: block;
      width: 100%;
      padding: 0.8rem 0.88rem;
    }

    .install-cmd code {
      justify-content: flex-start;
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .kicker-dot {
      opacity: 1;
      box-shadow: 0 0 0.5rem rgba(192, 122, 62, 0.45);
    }

    .kicker-dot.blink-in {
      animation: none;
    }
  }
</style>
