---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "aipm";
const description = "Claude Code is for coding. This is for PM-ing.";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox → task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">aipm<span class="cursor">_</span></h1>
    <p class="hero-tagline">Claude Code is for coding. <span class="hero-tagline-highlight">This is for PM-ing.</span></p>
    <pre class="install-cmd" onclick="navigator.clipboard.writeText('brew tap ComputelessComputer/aipm && brew install aipm')" title="Click to copy">
      <span class="install-cmd-header">
        <span class="terminal-dots"><span></span><span></span><span></span></span>
        <span class="terminal-title">terminal</span>
      </span>
      <code><span class="terminal-prompt">$</span> brew tap ComputelessComputer/aipm && brew install aipm</code>
      <span class="copy-hint">click to copy</span>
    </pre>
  </section>

  <!-- Value Props -->
  <section class="value-props">
    <div class="prop">
      <h3>local-first</h3>
      <p>Your tasks live as plain files on your filesystem. No servers, no sync, no lock-in. Grep, sed, or script your way through everything.</p>
    </div>
    <div class="prop">
      <h3>cli-first</h3>
      <p>Headless commands with JSON output. Built for scripting and AI coding agents. Works as well in a pipeline as it does interactively.</p>
    </div>
    <div class="prop">
      <h3>super fast</h3>
      <p>Native Rust TUI. Instant startup, zero latency navigation, no Electron, no browser. Just your terminal.</p>
    </div>
  </section>

  <!-- Demo -->
  <section class="demo">
    <h2>demo</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>features</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .hero-title {
    font-size: 4rem;
    margin-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 5rem;
    }
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    white-space: nowrap;
  }

  .hero-tagline-highlight {
    color: var(--color-accent);
    font-weight: 600;
  }

  .install-cmd {
    display: block;
    width: min(100%, 920px);
    margin: 0 auto;
    text-align: left;
    cursor: pointer;
    position: relative;
    border-radius: 14px;
    border: 1px solid #2b2f3a;
    background: linear-gradient(180deg, #0f131d 0%, #090c13 100%);
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.5);
    padding: 0;
    overflow: hidden;
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .install-cmd:hover {
    border-color: #3a8cff;
    transform: translateY(-1px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.62);
  }

  .install-cmd:active {
    transform: translateY(0);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.5);
  }

  .install-cmd-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.55rem 0.9rem;
    border-bottom: 1px solid #202531;
    background-color: #0d1119;
  }

  .terminal-dots {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .terminal-dots span {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    display: inline-block;
  }

  .terminal-dots span:nth-child(1) {
    background-color: #ff5f57;
  }

  .terminal-dots span:nth-child(2) {
    background-color: #febc2e;
  }

  .terminal-dots span:nth-child(3) {
    background-color: #28c840;
  }

  .terminal-title {
    color: #9aa6be;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    text-transform: lowercase;
  }

  .install-cmd code {
    display: block;
    background: none;
    border: 0;
    color: #e2e9f5;
    font-size: clamp(0.75rem, 2.2vw, 1.05rem);
    line-height: 1.45;
    padding: 1rem 1.05rem 0;
    white-space: nowrap;
  }

  .terminal-prompt {
    color: #5ba0ff;
    margin-right: 0.5ch;
  }

  .copy-hint {
    display: block;
    font-size: 0.7rem;
    color: #7f8ba3;
    margin-top: 0.65rem;
    padding: 0 1.05rem 1rem;
    text-align: right;
    text-transform: lowercase;
  }

  .install-cmd:hover .copy-hint {
    color: #b6c8e8;
  }

  @media (max-width: 640px) {
    .install-cmd code {
      overflow-x: auto;
      padding: 0.9rem 0.9rem 0;
    }

    .copy-hint {
      padding: 0 0.9rem 0.9rem;
    }
  }

  /* Value Props */
  .value-props {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .value-props {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .prop {
    padding: var(--space-lg);
  }

  .prop h3 {
    font-size: 1.125rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .prop p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    color: var(--color-accent);
    transition: all var(--transition-fast);
  }

  .cta-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  /* Demo */
  .demo {
    padding: var(--space-2xl) 0;
  }

  .demo h2 {
    margin-bottom: var(--space-lg);
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Features */
  .features {
    padding: var(--space-2xl) 0;
  }

  .features h2 {
    margin-bottom: var(--space-lg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature {
    padding: var(--space-lg);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .feature h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .feature p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

</style>
