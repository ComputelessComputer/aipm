---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "aipm";
const description = "AI-powered project management for the terminal";

const features = [
  {
    title: "Natural language task management",
    desc: "Just type what you need. The AI understands intent and executes through tool calls."
  },
  {
    title: "Email inbox → task list",
    desc: "Surfaces actionable emails via AI. Marketing and noise filtered out automatically."
  },
  {
    title: "File-per-task architecture",
    desc: "Each task is a markdown file with YAML front matter. Grep your way through tasks."
  },
  {
    title: "Full keyboard control",
    desc: "Vim-style bindings. Arrow keys. No mouse needed. Navigate instantly."
  },
  {
    title: "Multiple views",
    desc: "Buckets (columns), Timeline (chronological), Kanban (progress stages)."
  },
  {
    title: "Context-aware AI",
    desc: "Paste GitHub URLs, AI fetches context automatically. No manual copying."
  },
  {
    title: "Sub-tasks & dependencies",
    desc: "Hierarchical tasks with automatic parent progress sync."
  },
  {
    title: "Undo/history",
    desc: "Snapshot before every operation. Rollback anytime."
  }
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">aipm<span class="cursor">_</span></h1>
    <p class="hero-tagline">{description}</p>
    <pre class="install-cmd"><code>brew tap ComputelessComputer/aipm && brew install aipm</code></pre>
    <a href="https://github.com/ComputelessComputer/aipm" class="cta-btn" target="_blank" rel="noopener noreferrer">
      view on github →
    </a>
  </section>

  <!-- Demo -->
  <section class="demo">
    <h2>demo</h2>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/PGFg01h9LHU"
        title="aipm demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>features</h2>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Install -->
  <section class="install">
    <h2>install</h2>
    <div class="install-methods">
      <div class="install-method">
        <h3>homebrew (macos/linux)</h3>
        <pre><code>brew tap ComputelessComputer/aipm
brew install aipm</code></pre>
      </div>
      <div class="install-method">
        <h3>from source</h3>
        <pre><code>git clone https://github.com/ComputelessComputer/aipm.git
cd aipm
cargo build --release</code></pre>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .hero-title {
    font-size: 4rem;
    margin-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 5rem;
    }
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .install-cmd {
    display: inline-block;
    text-align: left;
    margin-bottom: var(--space-xl);
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    color: var(--color-accent);
    transition: all var(--transition-fast);
  }

  .cta-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  /* Demo */
  .demo {
    padding: var(--space-2xl) 0;
  }

  .demo h2 {
    margin-bottom: var(--space-lg);
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Features */
  .features {
    padding: var(--space-2xl) 0;
  }

  .features h2 {
    margin-bottom: var(--space-lg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature {
    padding: var(--space-lg);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .feature h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .feature p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Install */
  .install {
    padding: var(--space-2xl) 0;
  }

  .install h2 {
    margin-bottom: var(--space-lg);
  }

  .install-methods {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .install-methods {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .install-method h3 {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
    text-transform: lowercase;
  }

  .install-method pre {
    margin: 0;
  }
</style>
